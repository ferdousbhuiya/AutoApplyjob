{
  "info": {
    "name": "AutoApply API",
    "description": "Postman collection for the AutoApply backend (Gmail job scanning + AI resume/cover letter tailoring).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Gmail OAuth URL",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/gmail-url" }
        },
        {
          "name": "Gmail OAuth Callback",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/callback?code=AUTH_CODE_HERE" }
        },
        {
          "name": "Gmail Connection Status",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/status" }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": { "method": "GET", "url": "{{baseUrl}}/jobs?status=pending" }
        },
        {
          "name": "Get Job by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/jobs/1" }
        },
        {
          "name": "Trigger Gmail Scan",
          "request": { "method": "POST", "url": "{{baseUrl}}/jobs/scan" }
        },
        {
          "name": "Create Mock Job",
          "request": { "method": "POST", "url": "{{baseUrl}}/jobs/mock" }
        },
        {
          "name": "Approve Job",
          "request": { "method": "PUT", "url": "{{baseUrl}}/jobs/1/approve" }
        },
        {
          "name": "Skip Job",
          "request": { "method": "PUT", "url": "{{baseUrl}}/jobs/1/skip" }
        },
        {
          "name": "Delete Job",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/jobs/1" }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Extract Job Details",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/ai/extract",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailBody\": \"We are hiring a Data Analyst at Acme Corp. Requirements: SQL, Python, Power BI.\"\n}"
            }
          }
        },
        {
          "name": "Generate Tailored Application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/ai/generate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}
